# =============================================================================
# Microsoft Fabric – Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# Reference: https://12factor.net/config
# =============================================================================

# ── Azure Core ────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=sensor-anomaly-rg
AZURE_REGION=eastus
AZURE_TENANT_ID=your-azure-tenant-id

# ── Azure Event Hub ───────────────────────────────────────────────────────────
# Full connection string for the Event Hub namespace
EVENT_HUB_CONNECTION_STR=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=PublisherPolicy;SharedAccessKey=YOUR_KEY
EVENT_HUB_NAME=sensor-events
EVENT_HUB_NAMESPACE=your-namespace.servicebus.windows.net

# ── Microsoft Fabric Lakehouse ────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=your-fabric-workspace-guid
FABRIC_LAKEHOUSE_ID=your-fabric-lakehouse-guid
FABRIC_LAKEHOUSE_NAME=SensorLakehouse
FABRIC_ACCESS_TOKEN=                       # Azure AD bearer token (for REST loader)
ONELAKE_ACCOUNT_NAME=onelake

# ── Azure ML / AutoML ─────────────────────────────────────────────────────────
AML_SUBSCRIPTION_ID=your-azure-subscription-id
AML_RESOURCE_GROUP=sensor-anomaly-rg
AML_WORKSPACE_NAME=your-aml-workspace-name
AML_COMPUTE_CLUSTER=cpu-cluster

# ── MLflow Tracking ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=                       # e.g. azureml://your-workspace
MLFLOW_EXPERIMENT_NAME=sensor-anomaly-detection

# ── REST API ──────────────────────────────────────────────────────────────────
MODEL_PATH=models/model_latest.pkl
PORT=8000
API_KEY=                                   # Leave empty to disable auth
LOG_LEVEL=INFO
FLASK_DEBUG=false
MODEL_OUTPUT_DIR=models

# ── Azure Container Registry ──────────────────────────────────────────────────
ACR_NAME=sensoranomalyacr
API_IMAGE_TAG=latest
ACI_NAME=sensor-api
ACI_CPU=1
ACI_MEMORY_GB=1.5
ACI_PORT=8000

# ── Azure Monitor ─────────────────────────────────────────────────────────────
AZURE_MONITOR_WORKSPACE_ID=your-log-analytics-workspace-id

# ── Teams Notifications ───────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url

# ── Email Alerts (Azure Communication Services) ───────────────────────────────
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=YOUR_KEY
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=team@yourdomain.com,oncall@yourdomain.com

# ── Anomaly Monitoring ────────────────────────────────────────────────────────
ANOMALY_ALERT_THRESHOLD=0.10               # Alert when anomaly rate exceeds 10%
MONITOR_INTERVAL_SECONDS=60

# ── Power BI ──────────────────────────────────────────────────────────────────
POWERBI_CLIENT_ID=your-service-principal-client-id
POWERBI_CLIENT_SECRET=your-service-principal-secret
PBI_WORKSPACE_NAME=SensorAnomalyDashboard
PBI_DATASET_NAME=SensorAnomalyDataset

# ── Sensor Simulation ─────────────────────────────────────────────────────────
ANOMALY_RATE=0.05
PUBLISHER_BATCH_SIZE=100

# ── REST API URL (for health monitor) ─────────────────────────────────────────
REST_API_URL=http://localhost:8000
